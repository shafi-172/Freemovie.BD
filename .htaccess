# CineMax - Apache Configuration File (.htaccess)
# This file enhances performance and security of your website

# ========================================
# Enable GZIP Compression
# ========================================
<IfModule mod_deflate.c>
    # Compress HTML, CSS, JavaScript, Text, XML, SVG
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE image/svg+xml
    
    # Remove browser bugs
    BrowserMatch ^Mozilla/4 ^gzip-only-text/html$
    BrowserMatch ^Mozilla/4\.0[678] no-gzip
    BrowserMatch \bMSIE !^gzip-only-text/html$
    BrowserMatch \bMSI[E] !^gzip-only-text/html$
    Header append Vary User-Agent
</IfModule>

# ========================================
# Browser Caching
# ========================================
<IfModule mod_expires.c>
    ExpiresActive On
    
    # Default: 1 week
    ExpiresDefault "access plus 1 week"
    
    # HTML files: 1 hour
    ExpiresByType text/html "access plus 1 hour"
    
    # PDF: 1 week
    ExpiresByType application/pdf "access plus 1 week"
    
    # JavaScript: 1 year
    ExpiresByType text/javascript "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType application/x-javascript "access plus 1 year"
    
    # CSS: 1 year
    ExpiresByType text/css "access plus 1 year"
    
    # Images: 1 year
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    
    # Fonts: 1 year
    ExpiresByType font/truetype "access plus 1 year"
    ExpiresByType font/opentype "access plus 1 year"
    ExpiresByType application/x-font-woff "access plus 1 year"
</IfModule>

# ========================================
# Cache Control Headers
# ========================================
<IfModule mod_headers.c>
    <FilesMatch "\\.(jpg|jpeg|png|gif|ico|webp|svg)$">
        Header set Cache-Control "public, immutable, max-age=31536000"
    </FilesMatch>

    <FilesMatch "\\.(css|js)$">
        Header set Cache-Control "public, immutable, max-age=31536000"
    </FilesMatch>

    <FilesMatch "\\.(woff|woff2|ttf|otf|eot)$">
        Header set Cache-Control "public, immutable, max-age=31536000"
    </FilesMatch>

    <FilesMatch "\\.html$">
        Header set Cache-Control "public, max-age=3600"
    </FilesMatch>

    # Security Headers
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "no-referrer-when-downgrade"
</IfModule>

# ========================================
# Remove Server Signature
# ========================================
ServerSignature Off
ServerTokens Prod

# ========================================
# URL Rewriting
# ========================================
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Remove www from URL
    # RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
    # RewriteRule ^(.*)$ http://%1/$1 [R=301,L]
    
    # Force HTTPS
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
    
    # Direct to index.html for non-existent files
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    # RewriteRule ^(.*)$ /index.html [QSA,L]
</IfModule>

# ========================================
# Disable Directory Listing
# ========================================
<IfModule mod_autoindex.c>
    Options -Indexes
</IfModule>

# ========================================
# Set Default Character Encoding
# ========================================
AddDefaultCharset UTF-8

# ========================================
# PHP Configuration (if using PHP)
# ========================================
<IfModule mod_php.c>
    SetEnv register_globals 0
    SetEnv display_errors 0
    SetEnv log_errors 1
</IfModule>

# ========================================
# Block Access to Sensitive Files
# ========================================
<filesmatch "\.(php|php[345]|php[345]\.txt|phps|phtml|pht|phpt|pgif|pjpeg|pjpg|phtml)$">
    deny from all
</filesmatch>

# Block access to hidden files and directories
<FilesMatch "^\.|\.(?:php|phtml|php[345])$|\.htaccess$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# ========================================
# Error Pages (Optional)
# ========================================
# ErrorDocument 404 /404.html
# ErrorDocument 500 /500.html
# ErrorDocument 403 /403.html

# ========================================
# Disable Hotlinking
# ========================================
# This helps prevent bandwidth theft
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTP_REFERER} !^$
    RewriteCond %{HTTP_REFERER} !^https?://(www\.)?yoursite\.com/ [NC]
    # RewriteRule \.(jpg|jpeg|gif|png|webp|mp4|pdf)$ - [F,NC,L]
</IfModule>

# ========================================
# Enable CORS (if needed)
# ========================================
<IfModule mod_headers.c>
    # Uncomment to allow cross-origin requests
    # Header set Access-Control-Allow-Origin "*"
</IfModule>

# ========================================
# MIME Types
# ========================================
<IfModule mod_mime.c>
    AddType video/mp4 .mp4
    AddType video/webm .webm
    AddType image/webp .webp
    AddType image/svg+xml .svg
    AddType font/woff2 .woff2
    AddType font/woff .woff
</IfModule>
